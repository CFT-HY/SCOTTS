# Example input file

# How long the simulation takes
Lx  64
Ly	64
Lz	64
steps  100

# How big the simulation is
dx     1.0
dt     0.2

# Viscosity terms
Cav    0.0
C      0.35

# Potential parameters
# Lheat  0.1
# sigma  0.1
# lcorr  6.0

alpha 0.167705098312
gamma 0.0427050983125
lambda 0.0731762745781

T0 0.70710678
Tconst 0.86

# How often to write data
interval 5
silointerval 5

# Initial conditions
initial initps
initpsfile initial.txt div
initpsbins 200
#initpsfile dogfood.dat
#initpsbins 240

initnorm 1.0
initcutoff 1.0
initlength 0.5


bubbles 16

silodir ./silage

beta 1.0

scale 1.0

nucleation off

checkpointinterval -1
checkpointdir /wrk/weir/hydro/L1024-weak-0.2-Nb-640-dx2/

gwsource fluid

seed 90210

gstar 106.75

fftinterval 100
uetcstart -1
silosliceinterval -1
siloslicecoord 1

# Size of the critical bubble radius,
# if less than zero default to gaussian ansatz:
R_critical -1

# Value of phi at the centre of the nucleated bubble,
# if less than 0 default to broken phase value.
phimin -1

# Value of T at centre of fluid sphere, used if initial is set to "initfs" only.
T_central 1

# Radius of gaussian fluid sphere, used if initial is set to "initfs" only.
sphere_radius 10
