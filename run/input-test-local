# Example input file

# How long the simulation takes: volume and number of timesteps
# Note that if the simulation is checkpointed and restarts the cumulative
# number of timesteps is counted, so 'steps' would (for example) need to
# be increased if you wanted to run for longer.
Lx      40
Ly	40
Lz      40
steps  1000

# How big the simulation is: lattice spacing and timestep
dx     2.0
dt     0.2
 
# Viscosity terms. Cav is the artificial viscosity
# and is not currently used. C is the 'eta' term that
# takes energy out of the field and into the fluid.
# C = 0.63 gives vW = 0.44 with the code path.
Cav    0.0
C      0.63

# Example potential parameters (int BAG case, dimensionful eta).
alpha 0.167705098312
gamma 0.0427050983125
lambda 0.0731762745781

#Not used for BAG model
T0 0.70710678118654757

# Tconst is the initial temperature everywhere.
# NB: cooling is faked by nucleating ready-made bubbles.
Tconst 0.44538722

# How often to write data. "interval" is how often to write a line of
# global quantities to output_fname, and do any FFTs/power spectra that are
# compiled in. 
interval 100

# "silointerval" is the interval for writing visualisation data;
# if it is 0 or -1 then nothing is done
silointerval -1

# "silosliceinterval" is the inteval for writing a *slice* of data for
# visualisation, the slice is taken at the x-coordinate given by
# "siloslicecoord"
silosliceinterval 250
siloslicecoord 0

# Power spectra measurements. How often to write FFT's (i.e. field, fluid
# velocity, and GW power spectra) - set to -1 to disable.
fftinterval 100

# When to start uetcs (and therefore reference time).
# Set to -1 to disable uetcs.
# Can set to an integer corersponding to the timestep to start uetcs.
# -e.g "uetcstart 500" starts uetcs on timestep 500.
# Alternatively set to "scalar" followed by a float, in which case the code
# checks every fft output for whether the broken phase fraction exceeds
# the provided threshold and if it does it starts the uetcs.
# -e.g "uetcstart scalar 0.7" will start uetcs on the first fft output for which
# 70% of the volume is in the broken phase.  
uetcstart 500


# Initial conditions; choices are "shocktube", "bubble" and "initps"; only
# "bubble" should be currently used.
initial bubble

# Initps input files and options, unused if initial is not initps.
initpsfile initial.txt div
initpsbins 200

# How many bubbles to start off with. May be zero.
bubbles 1

# Where visualisation data gets stored. If silointerval is less than or
# equal to zero then this is not accessed.
silodir silage/

# Value of T at centre of fluid sphere, used if initial is set to "initfs" only.
T_central 1

# Radius of gaussian fluid sphere, used if initial is set to "initfs" only.
sphere_radius 10

# How much the gaussian ansatz for the initial bubble is enlarged by
scale 1.5

# Size of the critical bubble radius,
# if less than zero default to gaussian ansatz:
R_critical -1

# Value of phi at the centre of the nucleated bubble,
# if less than 0 default to broken phase value.
phimin -1

# Nucleation procedure; choices are "off", "list" or "file" 
# - "off" does nothing (the number of bubbles given above as 'bubbles' is
#   still created at the start however)
# - "list" is a comma-separated list without spaces of timesteps
#   at which bubbles should be nucleated, eg:
#   "nucleation list 1,2,100,200" (maximum length >2500 chars)
# - "file" (recommended) is a list of timesteps at which
#    bubbles should be nucleated in a separate file, eg:
#   "nucleation file nucleation-list". There may be more than
#   one nucleation attempt per timestep.
#   The program utils/nucproc.py produces output in this format.
nucleation off

# The checkpoint directory is always checked for a valid checkpoint
# (assuming it exists; if it does not then the code will run anyway)
# If checkpointinterval is 0 or -1 then no attempt will be made
# to write a checkpoint. If it is unfeasably big then a final
# checkpoint will still be made.
checkpointdir cp/
checkpointinterval -1

# Which ffts/uetcs do we want to do?
# fftoptions can be set to three different values:
# all - enable all ffts
# none - disable all ffts
# list - provide a comma seperated list of ffts to perform
#        from the following options:
#        scalars,vel,J,X,gw,shst.
fftoptions all


# What the gravitational wave power spectrum is sourced by
# choices are 'fluid', 'field' or 'both'. The default (if the choice
# is unrecognisable) is 'both'.
gwsource fluid

# What step should we turn on the evolution of the metric perturbations?
# This should be set to zero unless you have a reason to want to only study
# gws produced after a certain time.
metricstart 0

# The random seed. This must be set. The seed is 'salted' with the
# timestep every update so that results are reproducible across
# simulations. The randomness is used for bubble locations only.
seed 1234

gstar 106.75

