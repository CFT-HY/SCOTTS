# This is built with personal versions of single-precision FFTW3,
# HDF5, and SILO. I create a directory ~/local/, inside which I create
# a subdirectory installed/, and download and compile the source in
# there.
#
# Therefore, below you must edit the following in order to make it work
# for you:
# 
# * -I/home/weir/local/include/
# * -L/home/weir/local/lib/
#

#### CC ####

CC := mpicc -g -DMPI -DFFT -DSILO

#### CFLAGS ####

CFLAGS := -O3 -I/home/weir/local/include/

#### LIBS ####

LIBS := -L/home/weir/local/lib/ \
	-lsiloh5 -lhdf5 -lfftw3f_mpi -lfftw3f -lm -lstdc++ -lz

#### No user-serviceable parts below ####

OBJECTS := main.o evolve.o potential.o energy.o eos.o \
	transport.o initial.o output.o parameters.o silage.o \
	util.o papi.o arrangement.o fft.o alloc.o gw.o velps.o \
	checkpoint.o uetc.o initps.o silage_slice.o

BINARY := run/hydro

FILES := $(OBJECTS) $(BINARY)

all: hydro

hydro: $(OBJECTS)
	$(CC) $(CFLAGS) $(OBJECTS) $(LIBS) -o $(BINARY)

clean:
	rm -f $(FILES) *\~ *\#

veryclean: clean
	rm -f *\~ *\#
