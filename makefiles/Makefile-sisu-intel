# This Sisu makefile assumes that the Intel programming environment is being
# used, and that the the 'fftw' module is loaded.
#
# This makefile was last tested with:
#
# PrgEnv-intel/5.2.82
# fftw/3.3.4.11

# Get VERSION from common makefile
include makefiles/Makefile.common

#### CC ####

CC := cc -DMPI -DFFT

#### CFLAGS ####

CFLAGS := -O3 -qopt-prefetch -unroll-aggressive -no-prec-div \
	-fp-model fast=2 -align -fno-alias -fno-fnalias -ipo \
	-DVERSION=\"$(VERSION)\"

#### LIBS ####

LIBS := -lfftw3f_mpi -lfftw3f

#### No user-serviceable parts below ####

OBJECTS := main.o evolve.o potential.o energy.o eos.o \
	transport.o initial.o output.o parameters.o silage.o \
	util.o papi.o comms.o fft.o alloc.o gw.o velps.o \
	checkpoint.o uetc.o initps.o silage_slice.o

BINARY := run/hydro

FILES := $(OBJECTS) $(BINARY)

all: hydro

hydro: $(OBJECTS)
	$(CC) $(CFLAGS) $(OBJECTS) $(LIBS) -o $(BINARY)

clean:
	rm -f $(FILES) *\~ *\#

veryclean: clean
	rm -f *\~ *\#
