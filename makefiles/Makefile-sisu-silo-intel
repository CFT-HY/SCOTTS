# This makefile assumes that you have compiled and installed
# your own version of HDF5, and Silo
# with ~/local_sisu/ as the prefix.
#
# Assumes that the Intel compiler is being used, e.g. the result
# of `module list` could be:
#
# 1) intel/17.0.1.132   2) PrgEnv-intel/5.2.82
# 3) fftw/3.3.4.11

#### CC ####

CC := cc -DMPI -DFFT -DSILO -DBAG

#### CFLAGS ####

CFLAGS := -L$(HOME)/local_sisu/lib \
        -I$(HOME)/local_sisu/include \
        -O3 -opt-prefetch -unroll-aggressive -no-prec-div \
        -fp-model fast=2 -align -fno-alias -fno-fnalias -ipo


#### LIBS ####

LIBS := -lfftw3f_mpi -lfftw3f -lsiloh5 -lhdf5 -lstdc++ -lz


#### No user-serviceable parts below ####

OBJECTS := main.o evolve.o potential.o energy.o eos.o \
	transport.o initial.o output.o parameters.o silage.o \
	util.o papi.o comms.o fft.o alloc.o gw.o velps.o \
	checkpoint.o uetc.o initps.o silage_slice.o

BINARY := run/hydro

FILES := $(OBJECTS) $(BINARY)

all: hydro

hydro: $(OBJECTS)
	$(CC) $(CFLAGS) $(OBJECTS) $(LIBS) -o $(BINARY)

clean:
	rm -f $(FILES) *\~ *\#

veryclean: clean
	rm -f *\~ *\#
