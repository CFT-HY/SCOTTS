# Makefile for the COSMOS supercomputer
#
# Tested with modules:
#
#  1) cosmos.common            5) mpt/2.14
#  2) python/2.7.10            6) fftw3/3.3.4-intel-15.0
#  3) icomp/15.0.5.223         7) hdf5/1.8.13-intel-15.0
#  4) impi/5.0.3.049
#
# To use Silo, you may need to compile it yourself...
#

#### CC ####

CC := mpicc -g -DMPI -DFFT

#### CFLAGS ####

CFLAGS := -O3 -I$(HOME)/include/

#### LIBS ####

LIBS := -L$(HOME)/local/lib64/ \
	-lsiloh5 -lhdf5 -lfftw3f_mpi -lfftw3f -lm -lstdc++
	
#### No user-serviceable parts below ####

OBJECTS := main.o evolve.o potential.o energy.o eos.o \
	transport.o initial.o output.o parameters.o silage.o \
	util.o papi.o arrangement.o fft.o alloc.o gw.o velps.o \
	checkpoint.o uetc.o initps.o silage_slice.o

BINARY := run/hydro

FILES := $(OBJECTS) $(BINARY)

all: hydro

hydro: $(OBJECTS)
	$(CC) $(CFLAGS) $(OBJECTS) $(LIBS) -o $(BINARY)

clean:
	rm -f $(FILES) *\~ *\#

veryclean: clean
	rm -f *\~ *\#
